rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Safety Net: default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
    
    // 2. Candidate Resume Uploads Path
    match /resumes/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024 // Strict 10MB limit
                    && (
                      request.resource.contentType.matches('application/pdf') ||
                      request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document') ||
                      request.resource.contentType.matches('text/plain') ||
                      request.resource.contentType.matches('image/.*')
                    );
    }
    
    // 3. User Profiles Folder (Avatar pictures)
    match /profiles/{userId}/{fileName} {
      allow read: if true; // Publicly accessible to recruiters/others
      allow write: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024 // Max 5MB image limits
                    && request.resource.contentType.matches('image/.*');
    }
    
    // 4. Corporate Company Branding & Logos
    match /companies/{companyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }
  }
}
