rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Hardened Access Control Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Role-based retrieval helpers
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isCandidate() {
      return isSignedIn() && getUserRole() == 'candidate';
    }

    function isRecruiter() {
      return isSignedIn() && (getUserRole() == 'employer' || getUserRole() == 'recruiter' || getUserRole() == 'corporate');
    }

    function isConsultancy() {
      return isSignedIn() && (getUserRole() == 'consultancy' || getUserRole() == 'agency');
    }

    function isSystemAdmin() {
      return isAdmin() || (isSignedIn() && getUserRole() == 'admin');
    }

    // 3. Collection Rules with Specific Access Guardrails
    
    // Users Profiles Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isSystemAdmin() || isRecruiter() || isConsultancy();
      allow list: if isSystemAdmin() || isRecruiter() || isConsultancy();
      allow create, update: if isOwner(userId);
      allow delete: if isSystemAdmin();
    }
    
    // Candidates collection
    match /candidates/{candidateId} {
      allow get: if isOwner(candidateId) || isRecruiter() || isConsultancy() || isSystemAdmin();
      allow list: if isRecruiter() || isConsultancy() || isSystemAdmin();
      allow create, update: if isOwner(candidateId);
      allow delete: if isSystemAdmin();
    }
    
    // Consultancies collection
    match /consultancies/{consultancyId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(consultancyId);
      allow delete: if isSystemAdmin();
    }
    
    // Employers collection
    match /employers/{employerId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(employerId);
      allow delete: if isSystemAdmin();
    }
    
    // Companies collection
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(companyId);
      allow delete: if isSystemAdmin();
    }
    
    // Jobs postings - visible to all users, editable by recruiters/admins
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isRecruiter() || isConsultancy() || isSystemAdmin();
      allow update, delete: if isSystemAdmin() || (isSignedIn() && (resource.data.employerId == request.auth.uid || resource.data.userId == request.auth.uid));
    }
    match /company_jobs/{jobId} {
      allow read: if true;
      allow create: if isRecruiter() || isConsultancy() || isSystemAdmin();
      allow update, delete: if isSystemAdmin() || (isSignedIn() && (resource.data.companyId == request.auth.uid || resource.data.userId == request.auth.uid));
    }
    
    // Applications
    match /applications/{applicationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.candidateId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSystemAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.candidateId == request.auth.uid || isRecruiter() || isConsultancy()));
    }
    match /company_applications/{applicationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.candidateId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSystemAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.candidateId == request.auth.uid || isRecruiter() || isConsultancy()));
    }
    
    // Resumes and Resume Versions
    match /resumes/{resumeId} {
      allow read: if isSignedIn() && (isOwner(resumeId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isOwner(resumeId) || isSystemAdmin();
    }
    match /resume_versions/{versionId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSignedIn() && (request.resource == null || isOwner(request.resource.data.userId) || isSystemAdmin());
    }
    match /resume_analysis/{analysisId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSignedIn() && (request.resource == null || isOwner(request.resource.data.userId) || isSystemAdmin());
    }
    match /resume_scores/{scoreId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSignedIn() && (request.resource == null || isOwner(request.resource.data.userId) || isSystemAdmin());
    }
    match /resume_recommendations/{recommendationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSignedIn() && (request.resource == null || isOwner(request.resource.data.userId) || isSystemAdmin());
    }
    
    // Interviews and scheduled sessions
    match /interviews/{interviewId} {
      allow read: if isSignedIn() && (isOwner(resource.data.candidateId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSystemAdmin() || isRecruiter() || isConsultancy() || (isSignedIn() && request.resource != null && isOwner(request.resource.data.candidateId));
    }
    match /company_interviews/{interviewId} {
      allow read: if isSignedIn() && (isOwner(resource.data.candidateId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSystemAdmin() || isRecruiter() || isConsultancy() || (isSignedIn() && request.resource != null && isOwner(request.resource.data.candidateId));
    }
    match /interviews_scheduled/{interviewId} {
      allow read, write: if isSignedIn();
    }
    match /interview_sessions/{sessionId} {
      allow read, write: if isSignedIn();
    }
    match /interview_reports/{reportId} {
      allow read, write: if isSignedIn();
    }
    match /interview_questions/{questionId} {
      allow read, write: if isSignedIn();
    }
    match /interview_answers/{answerId} {
      allow read, write: if isSignedIn();
    }
    match /ai_reports/{reportId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isRecruiter() || isConsultancy() || isSystemAdmin());
      allow write: if isSystemAdmin() || (isSignedIn() && request.resource != null && isOwner(request.resource.data.userId));
    }
    match /job_recommendations/{recId} {
      allow read, write: if isSignedIn();
    }
    
    // Notifications and logs
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (request.resource == null || request.resource.data.userId == request.auth.uid || isRecruiter() || isConsultancy() || isSystemAdmin());
    }
    match /notification_preferences/{userId} {
      allow read, write: if isOwner(userId) || isSystemAdmin();
    }
    match /activity_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    match /submission_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    match /candidate_documents/{docId} {
      allow read, write: if isSignedIn();
    }
    match /company_activity_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    match /login_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    
    // Support and settings
    match /support_tickets/{ticketId} {
      allow read, write: if isSignedIn();
    }
    match /support/{ticketId} {
      allow read, write: if isSignedIn();
    }
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSystemAdmin();
    }
    match /system_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSystemAdmin();
    }
    
    // Admin list
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(adminId) || isSystemAdmin();
      allow delete: if isSystemAdmin();
    }
    
    // Leads Collection
    match /leads/{leadId} {
      allow read, write: if isSignedIn();
    }
    
    // Approvals Collection
    match /approvals/{approvalId} {
      allow read, write: if isSignedIn();
    }
    
    // Payments & Subscriptions
    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }
    
    // CMS Contents
    match /cms/{cmsId} {
      allow read: if isSignedIn();
      allow write: if isSystemAdmin();
    }
    
    // Email Templates
    match /email_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isSystemAdmin();
    }

    // Audit logs
    match /audit_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    
    // Social links
    match /social_links/{linkId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    // Clients
    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }
    
    // Consultancy Jobs
    match /consultancy_jobs/{jobId} {
      allow read: if true;
      allow create: if isConsultancy() || isSystemAdmin();
      allow update, delete: if isSystemAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid));
    }
    
    // Consultancy Candidates
    match /consultancy_candidates/{candidateId} {
      allow read, write: if isSignedIn();
    }
    
    // Placements
    match /placements/{placementId} {
      allow read, write: if isSignedIn();
    }
    
    // Team Members
    match /team_members/{memberId} {
      allow read, write: if isSignedIn();
    }
    
    // Message logs
    match /message_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    
    // Offers
    match /offers/{offerId} {
      allow read, write: if isSignedIn();
    }
    
    // Chats and nested Messages
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }
    
    // Career goals
    match /career_goals/{goalId} {
      allow read, write: if isSignedIn();
    }
    
    // Success predictions
    match /success_predictions/{predId} {
      allow read, write: if isSignedIn();
    }
    
    // Cover letters
    match /cover_letters/{letterId} {
      allow read, write: if isSignedIn();
    }
    
    // Resume templates
    match /resume_templates/{templateId} {
      allow read, write: if isSignedIn();
    }
    
    // Learning paths
    match /learning_paths/{pathId} {
      allow read, write: if isSignedIn();
    }
    
    // FAQs
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    // Blogs
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
