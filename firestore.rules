rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if a user is writing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Secure rule for Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Secure rule for Admins
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(adminId);
    }

    // Secure rule for Candidates
    match /candidates/{candidateId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(candidateId);
    }

    // Secure rule for Companies
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(companyId);
    }

    // Secure rule for Consultancies
    match /consultancies/{consultancyId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(consultancyId);
    }

    // Secure rule for Employers
    match /employers/{employerId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(employerId);
    }

    // Resumes collection
    match /resumes/{resumeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    // General fallback for all collections (ensures zero permission issues for authenticated sessions)
    match /{collectionName}/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
